<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Dashboard</h1>
    <li>
        <ul>
            <% events.forEach(e => { %>
            <li>
                <h3><%= e.event %></h3>
                <p><%= e.description%></p>
                    
                </li>
            <% }) %>
        </ul>
    </li>
</body>
</html>