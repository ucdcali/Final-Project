          <button>Delete</button>
        </form>
      </li>
    <% }) %>
  </ul>

</body>-->
</html> 
<script>function toggleVisibility(i) {
    if(sb75.checked == true){
      alert("hiii");
      i.style = "display:block";}
    else {i.style="display:none";}
  } </script>