<!DOCTYPE html>
<html>
<head>
  <title>Refactor App</title>
  <link rel="stylesheet" href="../static/styles.css">
</head>
<body>

  <h1>Event</h1>
  <form id="eventForm" class="form" action="/admin/dashboard" method="POST">
     <label><h3>Event Title</h3></label>
    <input id="event" name="event" placeholder="Event title">

    <h3>Event Description</h3>
    <input id="description" name="description" placeholder="Breif overview of event">
    <% buildings.forEach(b => { %>
      <div class="formOption">
          <h3><%= b.building %></h3>
          <% b.rooms.forEach((r, i) => {%>
            <li class="roomCheck">
              <ul><input type="checkbox" name=<%=i%> id=<%=b.building+i%>>
              <label for=<%=b.building+i%>><%=r%></label> </ul>
              <ul><input name=<%=b.building+i%> placeholder="Description" style="display:block" id="i"></ul>
            </li>
          <% }) %>        
      </div>
    <% }) %>
    <button>Add</button>
  </form>

  
</body>
</html> 
